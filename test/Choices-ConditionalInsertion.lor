
state
  weekend: true

character barista
  name: Alex

beat Order
  Alex: What would you like?
  choice
    + SeasonalDrinks if weekend
    Espresso
      Alex: One espresso!

beat SeasonalDrinks
  choice
    Pumpkin Spice Latte
      Alex: One PSL!
    Peppermint Mocha
      Alex: One peppermint mocha!

