
state
  fruits: ["apple", "banana", "cherry"]
  empty: []
  mixed: ["hello", 42, true, null]
  menu:
    espresso: 3
    latte: 5
  nested:
    items: ["a", "b"]
    meta:
      count: 2

beat Start
  "Array: $fruits"
  "Empty array: $empty"
  "Mixed array: $mixed"
  "Object: $menu"
  "Nested: $nested"

