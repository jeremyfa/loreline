<test>
- expected: |
    ~ Array: [apple, banana, cherry]

    ~ Empty array: []

    ~ Mixed array: [hello, 42, true, null]

    ~ Object: {espresso: 3, latte: 5}

    ~ Nested: {items: [a, b], meta: {count: 2}}
</test>
