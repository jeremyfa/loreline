
state
  weekend: false

beat Order
  choice
    + SeasonalDrinks if weekend
    Espresso -> PickedEspresso

beat SeasonalDrinks
  choice
    Pumpkin Spice -> PickedPSL

beat PickedEspresso
  You picked espresso

beat PickedPSL
  You picked PSL

