# Godot 4+ specific ignores
.godot/
/android/

# Generated by Godot editor
*.import
*.uid

# macOS
.DS_Store

# Generated files — addon binaries copied by CI/setup
/addons/loreline/bin/

# Story files — copied from sample/ (except hand-written test stories)
/story/*
!/story/TestAsync.lor
!/story/TestSaveRestore.lor

# Web test harness artifacts (created by run-web-test.sh)
/node_modules/
/package.json
/package-lock.json
/.tmp-web/

